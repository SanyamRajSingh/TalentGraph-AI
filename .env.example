APP_ENV=development
APP_NAME=TalentGraph AI

# Backend
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Datastores
POSTGRES_DB=talentgraph
POSTGRES_USER=talentgraph
POSTGRES_PASSWORD=talentgraph
DATABASE_URL=postgresql+psycopg://talentgraph:talentgraph@postgres:5432/talentgraph

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=talentgraph-password

CHROMA_HOST=chromadb
CHROMA_PORT=8000

# AI providers
OPENAI_API_KEY=
SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Feature flags
ENABLE_ROLE_DNA_GENERATOR=false
ENABLE_CANDIDATE_TWIN_BUILDER=false
ENABLE_RANKING_PIPELINE=false
ENABLE_GRAPH_INTEGRATION=false
ENABLE_EMBEDDING_ENGINE=false
